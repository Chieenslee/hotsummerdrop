{
  "manifest_version": 3,
  "name": "PUBG HOT Drop Support Tool",
  "version": "1.0",
  "description": "Tự động kích hoạt công cụ hỗ trợ cho game PUBG HOT Summer Drop.",
  "content_scripts": [
    {
      "matches": ["*://*.pubg.com/en/events/hotsummerdrop*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.pubg.com/*"]
    }
  ]
}
